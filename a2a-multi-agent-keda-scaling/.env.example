# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL_ID=gpt-4o

# Azure OpenAI (alternative)
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Agent URLs (for local development)
ORCHESTRATOR_HOST=localhost
ORCHESTRATOR_PORT=8080
INVOICE_AGENT_HOST=localhost
INVOICE_AGENT_PORT=8081
PO_AGENT_HOST=localhost
PO_AGENT_PORT=8082

# Agent URLs (for Kubernetes)
# INVOICE_AGENT_URL=http://invoice-agent-service:8081
# PO_AGENT_URL=http://po-agent-service:8082

# Azure Service Bus (for KEDA scaling)
# Set USE_SERVICEBUS=true to switch agents from HTTP to queue-based communication
USE_SERVICEBUS=false
SERVICEBUS_FQDN=your-namespace.servicebus.windows.net

# Logging
LOG_LEVEL=INFO
